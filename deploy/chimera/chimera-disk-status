#!/usr/bin/env python3
import datetime
import json
import pathlib
import sys

path = pathlib.Path('/opt/chimera/state/disk-monitor.json')
try:
    data = json.loads(path.read_text(encoding='utf-8'))
    expected = {'schemaVersion', 'status', 'checkedAt', 'rootUsedPercent', 'storageUsedPercent', 'snapshotBytes', 'webReleaseBytes', 'downloadBytes', 'dockerBytes'}
    if set(data) != expected or data['schemaVersion'] != 1 or data['status'] != 'ok':
        raise ValueError('unhealthy')
    checked = datetime.datetime.fromisoformat(data['checkedAt'].replace('Z', '+00:00'))
    age = datetime.datetime.now(datetime.timezone.utc) - checked
    if age < datetime.timedelta(0) or age > datetime.timedelta(hours=8):
        raise ValueError('stale')
    if not all(isinstance(data[key], int) and data[key] >= 0 for key in expected - {'schemaVersion', 'status', 'checkedAt'}):
        raise ValueError('invalid metrics')
except Exception:
    print('unhealthy', file=sys.stderr)
    raise SystemExit(1)
print('ok')
