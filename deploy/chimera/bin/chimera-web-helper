#!/usr/bin/env bash
set -euo pipefail

die() { printf 'Chimera Web command rejected\n' >&2; exit 1; }
command="${SSH_ORIGINAL_COMMAND:-}"
if [[ "$command" =~ ^scp\ -t\ (\.chimera-staging/web/[a-f0-9]{40}\.tar\.gz\.partial)$ ]]; then
  exec /usr/bin/scp -t -- "${BASH_REMATCH[1]}"
fi
if [[ "$command" =~ ^activate-web\ ([a-f0-9]{40})$ ]]; then
  exec /usr/bin/sudo -n /usr/local/libexec/chimera-web-activate <<< "activate-web ${BASH_REMATCH[1]}"
fi
die
