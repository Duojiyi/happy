#!/usr/bin/env bash
set -euo pipefail

die() { printf 'Chimera server command rejected\n' >&2; exit 1; }
command="${SSH_ORIGINAL_COMMAND:-}"
if [[ "$command" =~ ^scp\ -t\ (\.chimera-staging/server/[a-f0-9]{40}\.(oci|json|attestation)\.partial)$ ]]; then
  exec /usr/bin/scp -t -- "${BASH_REMATCH[1]}"
fi
if [[ "$command" =~ ^deploy-server\ ([a-f0-9]{40})\ (sha256:[a-f0-9]{64})$ ]]; then
  exec /usr/bin/sudo -n /usr/local/libexec/chimera-server-deploy <<< "deploy-server ${BASH_REMATCH[1]} ${BASH_REMATCH[2]}"
fi
if [[ "$command" =~ ^rollback-server\ ([a-f0-9]{40})$ ]]; then
  exec /usr/bin/sudo -n /usr/local/libexec/chimera-server-deploy <<< "rollback-server ${BASH_REMATCH[1]}"
fi
die
