#!/usr/bin/env python3
import pathlib
import sys
import tarfile

if len(sys.argv) != 2:
    raise SystemExit(2)
seen = set()
with tarfile.open(sys.argv[1], "r:gz") as bundle:
    members = bundle.getmembers()
    if not members or len(members) > 100000:
        raise SystemExit(1)
    total = 0
    for member in members:
        path = pathlib.PurePosixPath(member.name.replace("\\", "/"))
        normalized = str(path).removeprefix("./")
        if not normalized or path.is_absolute() or ".." in path.parts or normalized in seen:
            raise SystemExit(1)
        if not (member.isfile() or member.isdir()) or member.issym() or member.islnk() or member.isdev():
            raise SystemExit(1)
        seen.add(normalized)
        total += member.size
        if total > 2 * 1024 * 1024 * 1024:
            raise SystemExit(1)
    if "index.html" not in seen:
        raise SystemExit(1)
